---
import Base from '../layouts/Base.astro';
---
<Base title="404 — The Recipe Box">
  <div style="padding:80px 0;text-align:center;">
    <div style="font-size:48px;font-weight:300;color:var(--fg-m);line-height:1;margin-bottom:14px;">404</div>
    <p style="font-size:12px;color:var(--fg-m);margin-bottom:24px;">// recipe not found</p>
    <a href="/" style="font-size:11px;color:var(--fg-m);border:1px solid var(--border);border-radius:2px;padding:5px 12px;font-family:var(--font);transition:all 150ms ease;">← back to recipes</a>
  </div>
</Base>
