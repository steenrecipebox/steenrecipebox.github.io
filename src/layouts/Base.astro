---
// src/layouts/Base.astro
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
}

const {
  title       = 'The Recipe Box',
  description = 'Family recipes, collected and shared.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;

const nav = [
  { href: '/',       label: 'recipes' },
  { href: '/about',  label: 'about'   },
];

function active(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script is:inline>
    (function(){
      var s = localStorage.getItem('theme');
      var d = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', s || d);
    })();
  </script>
</head>
<body>
  <div class="wrap">

    <header class="site-header">
      <div class="header-row">
        <div>
          <a href="/" style="text-decoration:none">
            <span class="site-name">the recipe box<span class="cursor"></span></span>
          </a>
          <div class="site-tag">// family recipes, collected and shared</div>
        </div>
        <button class="theme-btn" id="themeToggle" aria-label="Toggle theme">[ dark ]</button>
      </div>
    </header>

    <nav class="site-nav">
      {nav.map(l => (
        <a href={l.href} class="nav-link" aria-current={active(l.href) ? 'page' : undefined}>
          {l.label}
        </a>
      ))}
    </nav>

    <slot />

    <footer class="site-footer">
      <span>// the recipe box</span>
      <span>family use only</span>
    </footer>

  </div>

  <script>
    function boot() {
      const btn  = document.getElementById('themeToggle');
      if (!btn) return;
      const html = document.documentElement;
      const sync = () => { btn.textContent = html.dataset.theme === 'dark' ? '[ light ]' : '[ dark ]'; };
      sync();
      btn.addEventListener('click', () => {
        const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        sync();
      });
    }
    boot();
    document.addEventListener('astro:after-swap', boot);
  </script>
</body>
</html>
